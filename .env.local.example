# Slack Bot Token (required) - create at https://api.slack.com/apps
# Needs scopes: channels:read, channels:write, chat:write, users:read,
#               files:read, files:write, reactions:write, pins:write,
#               bookmarks:read, bookmarks:write, emoji:read
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack User Token (optional) - needed for search_messages, reminders
# Needs scopes: search:read, reminders:read, reminders:write
SLACK_USER_TOKEN=xoxp-your-user-token-here

# Slack Signing Secret (optional) - for webhook verification
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack Workspace Team ID (optional)
SLACK_TEAM_ID=T0XXXXXXXXX

# --- Canvas & Lists (requires paid Slack plan) ---
# Additional scopes needed for canvas operations:
#   canvases:read   - read canvas content and sections
#   canvases:write  - create, edit, delete canvases and manage access
#
# Additional scopes needed for list operations:
#   lists:read      - read lists and list items
#   lists:write     - create, update, delete lists, items, and manage access
#
# Note: Canvas and List operations require a paid Slack plan (Pro or above).
# Without the correct plan, the API will return a "not_paid_plan" error.
